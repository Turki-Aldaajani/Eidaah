# =======================================
# Eidaah Backend - Environment Variables
# =======================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =======================================

# REQUIRED: Groq API Key (free, no credit card needed)
# 1. Go to https://console.groq.com/keys
# 2. Sign up / log in (Google account works)
# 3. Click "Create API Key"
# 4. Paste it below
GROQ_API_KEY=your_api_key_here

# OPTIONAL: Frontend URL for CORS (only needed in production)
# Set this to your deployed frontend URL to restrict API access.
# Leave commented out during local development.
# FRONTEND_URL=https://eidaah.vercel.app

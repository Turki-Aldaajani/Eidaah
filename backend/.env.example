# =======================================
# Eidaah Backend v3 - Environment Variables
# =======================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# REQUIRED: Groq API Key (free, no credit card needed)
# 1. Go to https://console.groq.com/keys
# 2. Sign up / log in
# 3. Click "Create API Key"
# 4. Paste it below
GROQ_API_KEY=your_api_key_here

# C4 · Video recommendations: YouTube Data API v3 key
# Get one at https://console.cloud.google.com/apis/credentials (enable
# "YouTube Data API v3"). Without it, /api/lesson_videos degrades gracefully to
# an empty result via the StaticVideoProvider fallback.
YOUTUBE_API_KEY=your_youtube_api_key_here

# REQUIRED IN PRODUCTION: Frontend URL for CORS (restricts allowed origins)
# Without this, CORS defaults to "*" (all origins allowed)
FRONTEND_URL=https://eidaah-jgqp.vercel.app

# =======================================
# Supabase (G1) — Database + Storage
# =======================================
# From your Supabase project: Project Settings -> API
# Setup guide: supabase/README.md
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role key: backend only — bypasses RLS. NEVER expose it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

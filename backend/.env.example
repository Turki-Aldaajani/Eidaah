# =======================================
# Eidaah Backend v3 - Environment Variables
# =======================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# REQUIRED: Groq API Key (free, no credit card needed)
# 1. Go to https://console.groq.com/keys
# 2. Sign up / log in
# 3. Click "Create API Key"
# 4. Paste it below
GROQ_API_KEY=your_api_key_here

# REQUIRED IN PRODUCTION: Frontend URL for CORS (restricts allowed origins)
# Without this, CORS defaults to "*" (all origins allowed)
FRONTEND_URL=https://eidaah-jgqp.vercel.app

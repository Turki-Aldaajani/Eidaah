# ==============================================
# Frontend Environment Variables
# ==============================================

# Backend API URL
# For local development:
REACT_APP_API_URL=http://localhost:8000

# For production deployment:
# REACT_APP_API_URL=https://your-backend-url.com

# YouTube Data API v3 key (used for Step 2 video search — frontend/src/lib/youtube/)
# Get one at https://console.cloud.google.com/apis/credentials
# SECURITY: this key is used directly from the browser (no backend proxy for this feature).
# You MUST restrict it in Google Cloud Console under "Application restrictions" -> "HTTP referrers"
# to this app's domain(s) — never leave a browser-exposed key unrestricted.
REACT_APP_YOUTUBE_API_KEY=
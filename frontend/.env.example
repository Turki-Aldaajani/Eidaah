# ==============================================
# Backend Environment Variables
# ==============================================

# Currently, the backend doesn't require environment variables
# for basic functionality. The AI model downloads automatically.

# Optional: If you want to add features later
# HUGGING_FACE_TOKEN=your_token_here
# DATABASE_URL=your_database_url
# SECRET_KEY=your_secret_key

# Note: This file is for documentation only.
# The backend will work without a .env file for local development.